# Flask environment: development | production | testing
FLASK_ENV=development

# Database (production on Railway: Supabase Transaction pooler, port 6543)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Local MySQL (used when DATABASE_URL is unset in development)
# DEV_DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/yamada_db

# Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=
JWT_SECRET_KEY=
WTF_CSRF_SECRET_KEY=

# CORS — comma-separated origins (add your Vercel URL in production)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Email
# console — log all emails (notifications, chat, password reset) to the Flask terminal
# smtp    — send real email via MAIL_* settings below
MAIL_BACKEND=console
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=Yamada Support <noreply@example.com>

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OpenRouteService routing API (optional — shipping distance calculation)
OPENROUTESERVICE_API_KEY=
