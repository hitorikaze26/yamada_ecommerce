# =============================================================================
# YAMADA E-COMMERCE — PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this to .env and fill in values.
# On Railway: set these via Railw̨ay Dashboard → Variables.
# =============================================================================

# Flask environment
FLASK_ENV=development          # development | production | testing

# ---------------------------------------------------------------------------
# DATABASE — REQUIRED in production
# ---------------------------------------------------------------------------
# Railway: use Supabase Transaction pooler (port 6543, not 5432)
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Local MySQL (fallback for development when DATABASE_URL is unset)
# DEV_DATABASE_URL=mysql+pymysql://root:changeme@localhost:3306/yamada_db

# ---------------------------------------------------------------------------
# SECURITY — REQUIRED in production (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# ---------------------------------------------------------------------------
SECRET_KEY=
JWT_SECRET_KEY=
WTF_CSRF_SECRET_KEY=

# ---------------------------------------------------------------------------
# CORS — add ALL origins that will call the API
# ---------------------------------------------------------------------------
# In production: comma-separated Vercel URLs
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---------------------------------------------------------------------------
# SUPABASE STORAGE — REQUIRED in production (replaces local file uploads)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key  # NOT the anon key!

# ---------------------------------------------------------------------------
# EMAIL (SMTP via Gmail) — REQUIRED for password reset, notifications
# ---------------------------------------------------------------------------
# Backend: "smtp" for real email, "console" for dev logging
MAIL_BACKEND=smtp
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
# Use a Gmail App Password (not your regular password)
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=Yamada Support <noreply@yourdomain.com>

# ---------------------------------------------------------------------------
# TWILIO (SMS) — optional for SMS-based password reset
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# OPENROUTESERVICE — optional for shipping distance calculation
# ---------------------------------------------------------------------------
OPENROUTESERVICE_API_KEY=

# ---------------------------------------------------------------------------
# PORT — Railway sets this automatically; no need to set manually
# ---------------------------------------------------------------------------
# PORT=5000
