# =============================================================================
# YAMADA E-COMMERCE — DUAL-ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy to .env and fill in values.
#
# LOCAL DEVELOPMENT (Flask run.py):
#   - Set FLASK_ENV=development
#   - Uses DEV_DATABASE_URL or DATABASE_URL
#   - Backend serves at http://127.0.0.1:5000
#
# PRODUCTION (Railway):
#   - Set FLASK_ENV=production via Railway Dashboard → Variables
#   - Railway sets PORT automatically
# =============================================================================

# Flask environment — "development" | "production" | "testing"
FLASK_ENV=development

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# Production: use Supabase via Railway Connection Pooler (port 6543)
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Local MySQL (fallback when DATABASE_URL is unset in dev)
# DEV_DATABASE_URL=mysql+pymysql://root:changeme@localhost:3306/yamada_db

# Local POSTGRESQL (alternative for local dev)
# DEV_DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/yamada_db

# ---------------------------------------------------------------------------
# SECURITY — REQUIRED in production (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# ---------------------------------------------------------------------------
SECRET_KEY=
JWT_SECRET_KEY=
WTF_CSRF_SECRET_KEY=

# ---------------------------------------------------------------------------
# CORS — FRONTEND_URL is the primary origin; CORS_ORIGINS adds additional ones
# ---------------------------------------------------------------------------
# In production: set FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS is comma-separated and auto-includes FRONTEND_URL + Railway domain
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---------------------------------------------------------------------------
# SUPABASE STORAGE
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Force Supabase uploads even in dev (default: uses local filesystem when supabase configured)
# FORCE_SUPABASE_UPLOADS=true

# ---------------------------------------------------------------------------
# EMAIL (SMTP via Gmail)
# ---------------------------------------------------------------------------
MAIL_BACKEND=smtp
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Yamada Support <noreply@yourdomain.com>

# ---------------------------------------------------------------------------
# TWILIO (SMS) — optional for SMS-based password reset
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# OPENROUTESERVICE — optional for shipping distance calculation
# ---------------------------------------------------------------------------
OPENROUTESERVICE_API_KEY=

# ---------------------------------------------------------------------------
# SOCKET.IO — restrict to your frontend origin in production
# ---------------------------------------------------------------------------
# SOCKETIO_CORS=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# API BASE URL — self-referencing URL for the backend
# ---------------------------------------------------------------------------
# In production on Railway: leave unset (auto-detected from RAILWAY_PUBLIC_DOMAIN)
# For custom domain or local dev:
# API_BASE_URL=http://127.0.0.1:5000/api

# ---------------------------------------------------------------------------
# PORT — Railway sets this automatically
# ---------------------------------------------------------------------------
# PORT=5000
