# =============================================================================
# YAMADA NEXT.JS — ENVIRONMENT VARIABLES
# =============================================================================
# LOCAL DEVELOPMENT (default): no .env.local needed — defaults to Flask on localhost
#   Client:  http://localhost:3000
#   Backend: http://127.0.0.1:5000/api
#
# PRODUCTION (Vercel): set NEXT_PUBLIC_API_BASE_URL in Vercel dashboard
#   NEXT_PUBLIC_API_BASE_URL=https://your-api.up.railway.app/api
# =============================================================================

# Flask API base URL (must end with /api)
# LOCAL: leave unset — auto-detects http://127.0.0.1:5000/api
# PRODUCTION: set to Railway URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000/api

# Philippine geographic data proxy (optional)
# NEXT_PUBLIC_PH_SGG_BASE_URL=https://psgc.gitlab.io/api

# Application environment (development | production)
# Controls deployment-specific behavior flags (see lib/env-config.ts)
# APP_ENV=development

# Individual environment flag overrides (each defaults based on APP_ENV):
# USE_LOCAL_STORAGE=true
# USE_PRODUCTION_COOKIES=false
# USE_PRODUCTION_URLS=false
# USE_RAILWAY_DETECTION=false
# USE_VERCEL_DETECTION=false
