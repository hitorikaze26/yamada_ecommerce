# Flask API base URL (must end with /api)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000/api

# Production (Vercel) — point at your Railway API:
# NEXT_PUBLIC_API_BASE_URL=https://your-api.up.railway.app/api

# Philippine geographic data proxy (optional)
# NEXT_PUBLIC_PH_SGG_BASE_URL=https://psgc.gitlab.io/api
