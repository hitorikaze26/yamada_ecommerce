# YAMADA API — copy to `.env` and uncomment ONE API_BASE_URL for your device.

# --- Local development ---

# Android emulator
# API_BASE_URL=http://10.0.2.2:5000/api

# iOS simulator
# API_BASE_URL=http://localhost:5000/api

# Physical device (replace with your PC LAN IP; phone and PC on same Wi-Fi)
# API_BASE_URL=http://192.168.1.100:5000/api

# --- Production (Render backend) ---

# API_BASE_URL=https://your-api.onrender.com/api

# Optional: public link base for product/store sharing (your Vercel web URL)
# APP_SHARE_BASE_URL=https://your-app.vercel.app

# Philippine geographic data (PSGC)
PH_SGG_BASE_URL=https://psgc.gitlab.io/api
