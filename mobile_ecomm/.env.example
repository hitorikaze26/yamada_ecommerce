# =============================================================================
# YAMADA MOBILE — ENVIRONMENT VARIABLES
# =============================================================================
# Copy to `.env` for LOCAL DEVELOPMENT only (Flutter run).
#
# PRODUCTION BUILDS (APK/IPA):
#   Use --dart-define at build time — .env is NEVER bundled in release builds.
#   See "Production Builds" section below for the full command.
#
# The .env file is only used in debug/profile mode via flutter_dotenv.
# For release builds, all config must come from --dart-define.
# =============================================================================

# =============================================================================
# REQUIRED: API_BASE_URL
# =============================================================================
# The Flask API base URL (must end with /api).
#
# LOCAL DEVELOPMENT (uncomment one):
#   Android emulator: http://10.0.2.2:5000/api
#   iOS simulator:    http://localhost:5000/api
#   Physical device:  http://<YOUR_LAN_IP>:5000/api
#
# PRODUCTION (Railway):
#   https://yamadaecommerce-production.up.railway.app/api

# Android emulator
# API_BASE_URL=http://10.0.2.2:5000/api

# iOS simulator
# API_BASE_URL=http://localhost:5000/api

# Physical device (replace with your PC LAN IP)
# API_BASE_URL=http://192.168.1.100:5000/api

# Railway production
# API_BASE_URL=https://yamadaecommerce-production.up.railway.app/api

# =============================================================================
# OPTIONAL: SUPABASE_STORAGE_URL
# =============================================================================
# The Supabase Storage public URL for direct image CDN access.
# The backend already resolves image URLs to absolute Supabase URLs in API
# responses — this is only needed as a fallback for relative paths.
#
# Format: https://<project>.supabase.co/storage/v1/object/public
# Example:
# SUPABASE_STORAGE_URL=https://ejbrslppplbraljaifaz.supabase.co/storage/v1/object/public

# =============================================================================
# OPTIONAL: PH_SGG_BASE_URL
# =============================================================================
# Philippine geographic data API (PSGC).
# Default: https://psgc.gitlab.io/api (change if you self-host it)
PH_SGG_BASE_URL=https://psgc.gitlab.io/api

# =============================================================================
# OPTIONAL: APP_SHARE_BASE_URL
# =============================================================================
# Vercel web app URL for generating product/listing share links.
# APP_SHARE_BASE_URL=https://yamada-ecommerce.vercel.app

# =============================================================================
# PRODUCTION BUILDS (using --dart-define)
# =============================================================================
# The .env file is NOT read in release builds. Use --dart-define instead:
#
#   flutter build apk --dart-define=API_BASE_URL=https://yamadaecommerce-production.up.railway.app/api
#
#   flutter build ios --dart-define=API_BASE_URL=https://yamadaecommerce-production.up.railway.app/api
#
# With all optional vars:
#   flutter build apk \
#     --dart-define=API_BASE_URL=https://yamadaecommerce-production.up.railway.app/api \
#     --dart-define=SUPABASE_STORAGE_URL=https://ejbrslppplbraljaifaz.supabase.co/storage/v1/object/public \
#     --dart-define=PH_SGG_BASE_URL=https://psgc.gitlab.io/api \
#     --dart-define=APP_SHARE_BASE_URL=https://yamada-ecommerce.vercel.app
#
# For iOS App Store / TestFlight builds:
#   flutter build ipa \
#     --export-method app-store \
#     --dart-define=API_BASE_URL=https://yamadaecommerce-production.up.railway.app/api \
#     --dart-define=SUPABASE_STORAGE_URL=https://ejbrslppplbraljaifaz.supabase.co/storage/v1/object/public
