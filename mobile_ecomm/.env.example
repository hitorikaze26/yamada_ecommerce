# YAMADA API — copy to `.env` for LOCAL DEVELOPMENT only.
#
# PRODUCTION BUILDS: Use --dart-define at build time:
#   flutter build apk --dart-define=API_BASE_URL=https://your-api.up.railway.app/api
#   flutter build ios --dart-define=API_BASE_URL=https://your-api.up.railway.app/api
#
# The .env file is NEVER referenced in release builds — only --dart-define is used.
# This prevents secrets from being bundled into the APK/IPA binary.

# --- Local development ---

# Android emulator
# API_BASE_URL=http://10.0.2.2:5000/api

# iOS simulator
# API_BASE_URL=http://localhost:5000/api

# Physical device (replace with your PC LAN IP; phone and PC on same Wi-Fi)
# API_BASE_URL=http://192.168.1.100:5000/api

# Philippine geographic data (PSGC)
PH_SGG_BASE_URL=https://psgc.gitlab.io/api

# --- Optional ---

# APP_SHARE_BASE_URL (Vercel web URL for product sharing links)
# APP_SHARE_BASE_URL=https://your-app.vercel.app
